<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WarungQ - Manajemen Warung</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; }
        .modal-content { background: white; margin: 10% auto; padding: 20px; border-radius: 8px; max-width: 500px; }
        .nav-link { cursor: pointer; }
        .stok-rendah { color: #ef4444; font-weight: bold; }
        .toast { position: fixed; bottom: 20px; right: 20px; background: #333; color: white; padding: 12px 24px; border-radius: 8px; display: none; z-index: 2000; }
        button { cursor: pointer; }
    </style>
</head>
<body class="bg-gray-100">

    <!-- NAVBAR -->
    <nav class="bg-green-600 text-white shadow-lg">
        <div class="container mx-auto px-4 py-4">
            <div class="flex justify-between items-center">
                <h1 class="text-2xl font-bold">🏪 WarungQ</h1>
                <div class="space-x-4">
                    <button onclick="showPage('produk')" class="hover:bg-green-700 px-3 py-2 rounded">📦 Produk</button>
                    <button onclick="showPage('transaksi')" class="hover:bg-green-700 px-3 py-2 rounded">💰 Transaksi</button>
                    <button onclick="showPage('hutang')" class="hover:bg-green-700 px-3 py-2 rounded">📝 Hutang</button>
                    <button onclick="showPage('laporan')" class="hover:bg-green-700 px-3 py-2 rounded">📊 Laporan</button>
                </div>
            </div>
        </div>
    </nav>

    <!-- MAIN CONTENT -->
    <main class="container mx-auto px-4 py-8">
        <div id="content">Loading...</div>
    </main>

    <!-- TOAST -->
    <div id="toast" class="toast"></div>

    <script>
        // ============ KONFIGURASI ============
        const auth = btoa('warung:admin123');
        
        // ============ HELPER FUNCTIONS ============
        function formatRupiah(angka) {
            return new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR' }).format(angka);
        }
        
        function showToast(message, type = 'success') {
            const toast = document.getElementById('toast');
            toast.textContent = message;
            toast.style.background = type === 'success' ? '#10b981' : '#ef4444';
            toast.style.display = 'block';
            setTimeout(() => { toast.style.display = 'none'; }, 3000);
        }
        
        async function apiCall(url, options = {}) {
            const defaultOptions = {
                headers: { 'Authorization': 'Basic ' + auth }
            };
            const res = await fetch(url, { ...defaultOptions, ...options });
            return res.json();
        }
        
        // ============ API PRODUK ============
        async function getProduk() {
            const data = await apiCall('/api/produk');
            return data.success ? data.data : [];
        }
        
        async function createProduk(nama, harga, stok) {
            return await apiCall('/api/produk', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Authorization': 'Basic ' + auth },
                body: JSON.stringify({ nama, harga: parseInt(harga), stok: parseInt(stok) })
            });
        }
        
        async function deleteProduk(id) {
            return await apiCall(`/api/produk/${id}`, { method: 'DELETE' });
        }
        
        // ============ API TRANSAKSI ============
        async function createTransaksi(produk_id, jumlah) {
            return await apiCall('/api/transaksi', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Authorization': 'Basic ' + auth },
                body: JSON.stringify({ produk_id, jumlah: parseInt(jumlah) })
            });
        }
        
        async function getLaporanMingguan() {
            const data = await apiCall('/api/transaksi/laporan/mingguan');
            return data.success ? data.data : [];
        }
        
        // ============ API HUTANG ============
        async function getHutang() {
            const data = await apiCall('/api/hutang');
            return data.success ? data.data : [];
        }
        
        async function createHutang(nama_pelanggan, jumlah) {
            return await apiCall('/api/hutang', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Authorization': 'Basic ' + auth },
                body: JSON.stringify({ nama_pelanggan, jumlah: parseInt(jumlah) })
            });
        }
        
        async function lunasiHutang(id) {
            return await apiCall(`/api/hutang/${id}/lunas`, { method: 'PUT' });
        }
        
        async function hapusHutang(id) {
            return await apiCall(`/api/hutang/${id}`, { method: 'DELETE' });
        }
        
        // ============ HALAMAN PRODUK ============
        async function renderProduk() {
            const produk = await getProduk();
            const html = `
                <div class="bg-white rounded-lg shadow p-6">
                    <div class="flex justify-between items-center mb-6">
                        <h2 class="text-2xl font-bold">📦 Manajemen Produk</h2>
                        <button onclick="tambahProduk()" class="bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700">+ Tambah Produk</button>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full">
                            <thead class="bg-gray-100">
                                <tr><th class="p-3 text-left">ID</th><th class="p-3 text-left">Nama</th><th class="p-3 text-left">Harga</th><th class="p-3 text-left">Stok</th><th class="p-3 text-left">Aksi</th></tr>
                            </thead>
                            <tbody>
                                ${produk.map(p => `
                                    <tr class="border-b">
                                        <td class="p-3">${p.id}</td>
                                        <td class="p-3 font-semibold">${p.nama}</td>
                                        <td class="p-3">${formatRupiah(p.harga)}</td>
                                        <td class="p-3 ${p.stok < 5 ? 'stok-rendah' : ''}">${p.stok}</td>
                                        <td class="p-3"><button onclick="hapusProduk(${p.id})" class="text-red-600 hover:text-red-800">🗑️ Hapus</button></td>
                                    </tr>
                                `).join('')}
                            </tbody>
                        </table>
                    </div>
                </div>
                <div id="modal" class="modal">
                    <div class="modal-content">
                        <h3 class="text-xl font-bold mb-4">Tambah Produk</h3>
                        <input type="text" id="namaProduk" placeholder="Nama Produk" class="w-full p-2 border rounded mb-3">
                        <input type="number" id="hargaProduk" placeholder="Harga" class="w-full p-2 border rounded mb-3">
                        <input type="number" id="stokProduk" placeholder="Stok" class="w-full p-2 border rounded mb-3">
                        <div class="flex justify-end gap-2">
                            <button onclick="closeModal()" class="bg-gray-500 text-white px-4 py-2 rounded">Batal</button>
                            <button onclick="simpanProduk()" class="bg-green-600 text-white px-4 py-2 rounded">Simpan</button>
                        </div>
                    </div>
                </div>
            `;
            document.getElementById('content').innerHTML = html;
        }
        
        window.tambahProduk = () => { document.getElementById('modal').style.display = 'block'; };
        window.closeModal = () => { document.getElementById('modal').style.display = 'none'; };
        window.simpanProduk = async () => {
            const nama = document.getElementById('namaProduk').value;
            const harga = document.getElementById('hargaProduk').value;
            const stok = document.getElementById('stokProduk').value;
            if (!nama || !harga) { showToast('Lengkapi data!', 'error'); return; }
            const result = await createProduk(nama, harga, stok);
            if (result.success) { showToast('Produk ditambahkan'); closeModal(); renderProduk(); }
            else showToast(result.message, 'error');
        };
        window.hapusProduk = async (id) => {
            if (confirm('Yakin hapus?')) { 
                const result = await deleteProduk(id); 
                if (result.success) { showToast('Produk dihapus'); renderProduk(); } 
            }
        };
        
        // ============ HALAMAN TRANSAKSI ============
        async function renderTransaksi() {
            const produk = await getProduk();
            const html = `
                <div class="bg-white rounded-lg shadow p-6 max-w-md mx-auto">
                    <h2 class="text-2xl font-bold mb-6">💰 Transaksi Penjualan</h2>
                    <div class="mb-4">
                        <label class="block mb-2 font-semibold">Pilih Produk</label>
                        <select id="pilihProduk" class="w-full p-2 border rounded" onchange="hitungTotal()">
                            <option value="">-- Pilih --</option>
                            ${produk.map(p => `<option value="${p.id}" data-harga="${p.harga}" data-stok="${p.stok}">${p.nama} - ${formatRupiah(p.harga)} (Stok: ${p.stok})</option>`).join('')}
                        </select>
                    </div>
                    <div class="mb-4">
                        <label class="block mb-2 font-semibold">Jumlah</label>
                        <input type="number" id="jumlahBeli" class="w-full p-2 border rounded" oninput="hitungTotal()">
                    </div>
                    <div class="mb-4 p-4 bg-gray-100 rounded">
                        <p class="font-semibold">Total Harga:</p>
                        <p id="totalHarga" class="text-2xl font-bold text-green-600">Rp 0</p>
                    </div>
                    <button onclick="prosesTransaksi()" class="w-full bg-green-600 text-white py-3 rounded text-lg hover:bg-green-700">✅ Proses Transaksi</button>
                </div>
            `;
            document.getElementById('content').innerHTML = html;
        }
        
        window.hitungTotal = () => {
            const select = document.getElementById('pilihProduk');
            const jumlah = parseInt(document.getElementById('jumlahBeli')?.value) || 0;
            const harga = select.options[select.selectedIndex]?.dataset?.harga || 0;
            document.getElementById('totalHarga').innerHTML = formatRupiah(harga * jumlah);
        };
        window.prosesTransaksi = async () => {
            const select = document.getElementById('pilihProduk');
            const produkId = select.value;
            const jumlah = parseInt(document.getElementById('jumlahBeli').value);
            if (!produkId) { showToast('Pilih produk', 'error'); return; }
            const stokTersedia = parseInt(select.options[select.selectedIndex].dataset.stok);
            if (jumlah > stokTersedia) { showToast('Stok tidak cukup', 'error'); return; }
            const result = await createTransaksi(produkId, jumlah);
            if (result.success) { 
                showToast(`Transaksi berhasil! ${formatRupiah(result.data.total_harga)}`); 
                renderTransaksi(); 
            } else showToast(result.message, 'error');
        };
        
        // ============ HALAMAN HUTANG ============
        async function renderHutang() {
            const hutang = await getHutang();
            const total = hutang.filter(h => h.status === 'belum_lunas').reduce((s, h) => s + h.jumlah, 0);
            const html = `
                <div class="bg-white rounded-lg shadow p-6">
                    <div class="flex justify-between items-center mb-6">
                        <h2 class="text-2xl font-bold">📝 Manajemen Hutang</h2>
                        <button onclick="tambahHutang()" class="bg-green-600 text-white px-4 py-2 rounded">+ Tambah Hutang</button>
                    </div>
                    <div class="bg-yellow-100 p-4 rounded mb-6">
                        <p class="font-semibold">Total Hutang Belum Lunas:</p>
                        <p class="text-2xl font-bold text-red-600">${formatRupiah(total)}</p>
                    </div>
                    <table class="w-full">
                        <thead class="bg-gray-100">
                            <tr><th class="p-3">Pelanggan</th><th class="p-3">Jumlah</th><th class="p-3">Status</th><th class="p-3">Aksi</th></tr>
                        </thead>
                        <tbody>
                            ${hutang.map(h => `
                                <tr class="border-b">
                                    <td class="p-3">${h.nama_pelanggan}</td>
                                    <td class="p-3">${formatRupiah(h.jumlah)}</td>
                                    <td class="p-3"><span class="px-2 py-1 rounded text-sm ${h.status === 'lunas' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'}">${h.status === 'lunas' ? 'Lunas' : 'Belum Lunas'}</span></td>
                                    <td class="p-3">
                                        ${h.status !== 'lunas' ? `<button onclick="lunasHutang(${h.id})" class="text-green-600 mr-2">✅ Lunasi</button>` : ''}
                                        <button onclick="hapusHutang(${h.id})" class="text-red-600">🗑️</button>
                                    </td>
                                </tr>
                            `).join('')}
                        </tbody>
                    </table>
                </div>
                <div id="modalHutang" class="modal">
                    <div class="modal-content">
                        <h3 class="text-xl font-bold mb-4">Tambah Hutang</h3>
                        <input type="text" id="namaPelanggan" placeholder="Nama Pelanggan" class="w-full p-2 border rounded mb-3">
                        <input type="number" id="jumlahHutang" placeholder="Jumlah Hutang" class="w-full p-2 border rounded mb-3">
                        <div class="flex justify-end gap-2">
                            <button onclick="closeModalHutang()" class="bg-gray-500 text-white px-4 py-2 rounded">Batal</button>
                            <button onclick="simpanHutang()" class="bg-green-600 text-white px-4 py-2 rounded">Simpan</button>
                        </div>
                    </div>
                </div>
            `;
            document.getElementById('content').innerHTML = html;
        }
        
        window.tambahHutang = () => { document.getElementById('modalHutang').style.display = 'block'; };
        window.closeModalHutang = () => { document.getElementById('modalHutang').style.display = 'none'; };
        window.simpanHutang = async () => {
            const nama = document.getElementById('namaPelanggan').value;
            const jumlah = document.getElementById('jumlahHutang').value;
            if (!nama || !jumlah) { showToast('Lengkapi data', 'error'); return; }
            const result = await createHutang(nama, jumlah);
            if (result.success) { showToast('Hutang ditambahkan'); closeModalHutang(); renderHutang(); }
        };
        window.lunasHutang = async (id) => { 
            await lunasiHutang(id); 
            showToast('Hutang lunas'); 
            renderHutang(); 
        };
        window.hapusHutang = async (id) => { 
            if (confirm('Hapus hutang ini?')) { 
                await hapusHutang(id); 
                renderHutang(); 
            } 
        };
        
                // ============ HALAMAN LAPORAN (VERSION BARU) ============
        async function renderLaporan() {
            try {
                // Tampilkan loading dulu
                document.getElementById('content').innerHTML = `
                    <div class="bg-white rounded-lg shadow p-6 text-center">
                        <p class="text-gray-500">📊 Memuat laporan...</p>
                    </div>
                `;
                
                // Panggil API
                const auth = btoa('warung:admin123');
                const response = await fetch('/api/transaksi/laporan/mingguan', {
                    headers: { 'Authorization': 'Basic ' + auth }
                });
                
                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}`);
                }
                
                const result = await response.json();
                console.log('Laporan data:', result);
                
                const laporan = result.data || [];
                const total = laporan.reduce((s, i) => s + (i.omset || 0), 0);
                
                if (laporan.length === 0) {
                    document.getElementById('content').innerHTML = `
                        <div class="bg-white rounded-lg shadow p-6">
                            <h2 class="text-2xl font-bold mb-6">📊 Laporan Penjualan</h2>
                            <div class="bg-yellow-100 border border-yellow-400 text-yellow-700 px-4 py-3 rounded">
                                <p>⚠️ Belum ada data penjualan.</p>
                                <p class="text-sm mt-2">Silakan buat transaksi terlebih dahulu di menu <strong>Transaksi</strong>.</p>
                            </div>
                        </div>
                    `;
                    return;
                }
                
                let tabelHtml = `
                    <table class="w-full">
                        <thead class="bg-gray-100">
                            <tr>
                                <th class="p-3 text-left">Tanggal</th>
                                <th class="p-3 text-left">Omset</th>
                            </tr>
                        </thead>
                        <tbody>
                `;
                
                for (const item of laporan) {
                    tabelHtml += `
                        <tr class="border-b">
                            <td class="p-3">${item.tanggal}</td>
                            <td class="p-3 font-bold text-green-600">${formatRupiah(item.omset)}</td>
                        </tr>
                    `;
                }
                
                tabelHtml += `
                        </tbody>
                    </table>
                `;
                
                document.getElementById('content').innerHTML = `
                    <div class="bg-white rounded-lg shadow p-6">
                        <h2 class="text-2xl font-bold mb-6">📊 Laporan Penjualan</h2>
                        
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                            <div class="bg-gradient-to-r from-green-500 to-green-600 text-white p-4 rounded-lg">
                                <p class="text-sm">Total Omset (7 Hari)</p>
                                <p class="text-2xl font-bold">${formatRupiah(total)}</p>
                            </div>
                            <div class="bg-gradient-to-r from-blue-500 to-blue-600 text-white p-4 rounded-lg">
                                <p class="text-sm">Periode Transaksi</p>
                                <p class="text-2xl font-bold">${laporan.length} Hari</p>
                            </div>
                        </div>
                        
                        <h3 class="text-lg font-bold mb-3">Detail Penjualan per Tanggal</h3>
                        <div class="overflow-x-auto">
                            ${tabelHtml}
                        </div>
                    </div>
                `;
                
            } catch (error) {
                console.error('Laporan error:', error);
                document.getElementById('content').innerHTML = `
                    <div class="bg-white rounded-lg shadow p-6">
                        <h2 class="text-2xl font-bold mb-6">📊 Laporan Penjualan</h2>
                        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded">
                            <p>❌ Gagal memuat laporan</p>
                            <p class="text-sm mt-2">Error: ${error.message}</p>
                            <p class="text-sm mt-2">Pastikan server berjalan di terminal:</p>
                            <code class="block bg-gray-800 text-white p-2 rounded mt-2 text-xs">node backend/server.js</code>
                        </div>
                    </div>
                `;
            }
        }
        
        // ============ PAGE ROUTER ============
        window.showPage = (page) => {
            if (page === 'produk') renderProduk();
            else if (page === 'transaksi') renderTransaksi();
            else if (page === 'hutang') renderHutang();
            else if (page === 'laporan') renderLaporan();
        };
        
        // ============ LOAD HALAMAN DEFAULT ============
        renderProduk();
    </script>
</body>
</html>